<Application
    x:Class="StudioFeel.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- WinUI 3 Resources -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />

                <!-- Custom Theme -->
                <ResourceDictionary.ThemeDictionaries>
                    <ResourceDictionary x:Key="Light">
                        <SolidColorBrush x:Key="RootBackground" Color="#F3F3F3"/>
                        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>
                        <SolidColorBrush x:Key="AccentBrush" Color="#6B4CFF"/>
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="Dark">
                        <SolidColorBrush x:Key="RootBackground" Color="#1A1A1A"/>
                        <SolidColorBrush x:Key="CardBackground" Color="#252525"/>
                        <SolidColorBrush x:Key="AccentBrush" Color="#8A7FFF"/>
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
