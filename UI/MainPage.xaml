<!-- ============================================================================
     StudioFeel — Main Page
     The primary UI window containing the EQ controls and visualizer
     ============================================================================ -->

<Page
    x:Class="StudioFeel.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:converters="using:StudioFeel.Converters">

    <Page.Resources>
        <!-- Converters -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:GainToBrushConverter x:Key="GainToBrush"/>
    </Page.Resources>

    <Grid Background="{ThemeResource RootBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Main Content -->
            <RowDefinition Height="Auto"/>   <!-- Footer/Status -->
        </Grid.RowDefinitions>

        <!-- ================================================================== -->
        <!-- Header: App title, device selector, power toggle -->
        <!-- ================================================================== -->

        <Grid Grid.Row="0" Padding="20,16,20,16" Background="{ThemeResource CardBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Logo and Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE91D;" FontSize="28" Foreground="{ThemeResource AccentBrush}"/>
                <TextBlock Text="StudioFeel" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Device Selector -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                <TextBlock Text="Output:" VerticalAlignment="Center" Opacity="0.7"/>
                <controls:DropDownButton x:Name="DeviceSelector" Width="240">
                    <controls:DropDownButton.Content>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{x:Bind ViewModel.SelectedDeviceName, Mode=OneWay}"/>
                            <FontIcon Glyph="&#xE70D;" FontSize="12" Opacity="0.7"/>
                        </StackPanel>
                    </controls:DropDownButton.Content>
                </controls:DropDownButton>
            </StackPanel>

            <!-- Power Toggle -->
            <ToggleSwitch Grid.Column="2"
                          IsOn="{x:Bind ViewModel.IsEQEnabled, Mode=TwoWay}"
                          OffContent="Off"
                          OnContent="On"/>
        </Grid>

        <!-- ================================================================== -->
        <!-- Main Content: Visualizer + EQ Bands -->
        <!-- ================================================================== -->

        <Grid Grid.Row="1" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>      <!-- Visualizer -->
                <RowDefinition Height="Auto"/>   <!-- Bands -->
            </Grid.RowDefinitions>

            <!-- Frequency Response Visualizer -->
            <Border Grid.Row="0"
                    Background="{ThemeResource CardBackground}"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Visualizer Header -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="Frequency Response" FontWeight="SemiBold"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="16">
                            <TextBlock Opacity="0.7" FontSize="12">
                                <Run Text="20 Hz"/>
                            </TextBlock>
                            <TextBlock Opacity="0.7" FontSize="12">
                                <Run Text="1 kHz"/>
                            </TextBlock>
                            <TextBlock Opacity="0.7" FontSize="12">
                                <Run Text="20 kHz"/>
                            </TextBlock>
                        </StackPanel>
                    </Grid>

                    <!-- EQ Curve Canvas -->
                    <Canvas x:Name="FrequencyCurveCanvas"
                            Grid.Row="1"
                            Height="200"
                            Background="Transparent">
                        <!-- Grid Lines -->
                        <Line X1="0" Y1="100" X2="9999" Y2="100" Stroke="#40FFFFFF" StrokeThickness="1"/>
                        <Line X1="0" Y1="50" X2="9999" Y2="50" Stroke="#20FFFFFF" StrokeThickness="1" StrokeDashArray="4,4"/>
                        <Line X1="0" Y1="150" X2="9999" Y2="150" Stroke="#20FFFFFF" StrokeThickness="1" StrokeDashArray="4,4"/>

                        <!-- The EQ curve (polyline) -->
                        <Polyline x:Name="EQCurve"
                                  Points=""
                                  Stroke="{ThemeResource AccentBrush}"
                                  StrokeThickness="3"
                                  Fill="Transparent"/>
                    </Canvas>
                </Grid>
            </Border>

            <!-- ================================================================== -->
            <!-- EQ Bands Grid -->
            <!-- ================================================================== -->

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{x:Bind ViewModel.Bands}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
                            <Border Background="{ThemeResource CardBackground}"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,0,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>   <!-- Enable -->
                                        <ColumnDefinition Width="*"/>      <!-- Band Info -->
                                        <ColumnDefinition Width="120"/>    <!-- Type -->
                                        <ColumnDefinition Width="100"/>    <!-- Freq -->
                                        <ColumnDefinition Width="80"/>     <!-- Q -->
                                        <ColumnDefinition Width="120"/>    <!-- Gain -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Enable Toggle -->
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding Enabled, Mode=TwoWay}"
                                              Margin="0,0,16,0"
                                              VerticalAlignment="Center"/>

                                    <!-- Band Label -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Label}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="("
                                                   Opacity="0.7"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding TypeDisplay}"
                                                   Opacity="0.7"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=")"
                                                   Opacity="0.7"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Filter Type -->
                                    <ComboBox Grid.Column="2"
                                              SelectedIndex="{Binding TypeIndex, Mode=TwoWay}"
                                              PlaceholderText="Type">
                                        <ComboBoxItem Content="Peaking"/>
                                        <ComboBoxItem Content="Low Shelf"/>
                                        <ComboBoxItem Content="High Shelf"/>
                                        <ComboBoxItem Content="Lowpass"/>
                                        <ComboBoxItem Content="Highpass"/>
                                        <ComboBoxItem Content="Notch"/>
                                    </ComboBox>

                                    <!-- Frequency -->
                                    <NumberBox Grid.Column="3"
                                               Value="{Binding Frequency, Mode=TwoWay}"
                                               Minimum="20"
                                               Maximum="20000"
                                               SmallChange="10"
                                               LargeChange="100"
                                               SpinButtonPlacementMode="Compact"
                                               Header="Hz"/>

                                    <!-- Q Factor -->
                                    <NumberBox Grid.Column="4"
                                               Value="{Binding Q, Mode=TwoWay}"
                                               Minimum="0.1"
                                               Maximum="10"
                                               SmallChange="0.1"
                                               LargeChange="0.5"
                                               SpinButtonPlacementMode="Compact"
                                               Margin="8,0,0,0"/>

                                    <!-- Gain Slider -->
                                    <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8" Margin="16,0,0,0">
                                        <Slider Value="{Binding Gain, Mode=TwoWay}"
                                                Minimum="-24"
                                                Maximum="24"
                                                StepFrequency="0.5"
                                                Width="80"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding GainDisplay}"
                                                   Width="40"
                                                   TextAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ================================================================== -->
        <!-- Footer: Master Gain, Presets, Reset -->
        <!-- ================================================================== -->

        <Grid Grid.Row="2" Padding="20,16,20,16" Background="{ThemeResource CardBackground}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Master Gain -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" MaxWidth="300">
                <TextBlock Text="Master" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <Slider Value="{x:Bind ViewModel.MasterGain, Mode=TwoWay}"
                        Minimum="-12"
                        Maximum="12"
                        StepFrequency="0.5"
                        Width="150"
                        VerticalAlignment="Center"/>
                <TextBlock Text="{x:Bind ViewModel.MasterGainDisplay}"
                           Width="40"
                           TextAlignment="Right"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Presets -->
            <controls:DropDownButton Grid.Column="1" Content="Presets">
                <controls:DropDownButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutSubItem Text="Factory">
                            <MenuFlyoutItem Text="Flat" Click="{x:Bind ViewModel.LoadPresetFlat}"/>
                            <MenuFlyoutItem Text="Bass Boost" Click="{x:Bind ViewModel.LoadPresetBassBoost}"/>
                            <MenuFlyoutItem Text="Treble Boost" Click="{x:Bind ViewModel.LoadPresetTrebleBoost}"/>
                            <MenuFlyoutItem Text="Voice Clarity" Click="{x:Bind ViewModel.LoadPresetVoiceClarity}"/>
                            <MenuFlyoutItem Text="Pop Music" Click="{x:Bind ViewModel.LoadPresetPop}"/>
                            <MenuFlyoutItem Text="Rock Music" Click="{x:Bind ViewModel.LoadPresetRock}"/>
                            <MenuFlyoutItem Text="Classical" Click="{x:Bind ViewModel.LoadPresetClassical}"/>
                            <MenuFlyoutItem Text="Gaming" Click="{x:Bind ViewModel.LoadPresetGaming}"/>
                            <MenuFlyoutItem Text="Cinema" Click="{x:Bind ViewModel.LoadPresetCinema}"/>
                            <MenuFlyoutItem Text="Podcast" Click="{x:Bind ViewModel.LoadPresetPodcast}"/>
                        </MenuFlyoutSubItem>
                        <MenuFlyoutSeparator/>
                        <MenuFlyoutItem Text="Save As..."/>
                        <MenuFlyoutItem Text="Import Preset..."/>
                        <MenuFlyoutItem Text="Export Preset..."/>
                    </MenuFlyout>
                </controls:DropDownButton.Flyout>
            </controls:DropDownButton>

            <!-- Reset -->
            <Button Grid.Column="2"
                    Content="Reset"
                    Click="{x:Bind ViewModel.ResetToFlat}"
                    Margin="8,0,0,0"/>
        </Grid>
    </Grid>
</Page>
